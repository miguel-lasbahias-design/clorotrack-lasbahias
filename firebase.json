{
  "hosting": [
    {
      "target": "maquicontrol",
      "public": "dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        { "source": "**", "destination": "/index.html" }
      ]
    },
    {
      "target": "clorotrack",
      "public": "clorotrack-public",
      "ignore": ["firebase.json", "**/.*"],
      "rewrites": [
        {
          "source": "/api/claude",
          "function": {
            "functionId": "claudeProxy",
            "region": "us-central1"
          }
        },
        { "source": "**", "destination": "/index.html" }
      ]
    }
  ],
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": []
    }
  ]
}
